[MASTER]
ignore =
    .venv,
    venv,
    __pycache__,
    build,
    dist,
    .mypy_cache,
    .pytest_cache,
    .eggs,
    migrations

# Add backend/ to sys.path so that `from app.xxx import` resolves correctly
init-hook='import sys; sys.path.insert(0, "backend")'

[MESSAGES CONTROL]
disable =
    import-error,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    used-before-assignment,
    unused-argument

[REPORTS]
output-format=colorized
reports=no

[FORMAT]
max-line-length=100
indent-string='    '

[DESIGN]
max-args=8
max-attributes=15
max-locals=20
max-branches=12
max-statements=60

[TYPECHECK]
ignored-classes=optparse.Values,thread._local,_thread._local

[BASIC]
# Allow PascalCase for SQLAlchemy enum members (renaming to UPPER_CASE would
# break DB schema values and all callers across the codebase)
class-const-rgx = ([A-Z_][A-Z0-9_]*|[A-Za-z_][A-Za-z0-9_]*)

[VARIABLES]
additional-builtins=_

[STRING]
check-quote-consistency=yes
check-str-concat-over-line-jumps=yes
